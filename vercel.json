{
  "version": 2,
  "builds": [
    { "src": "*.php",       "use": "vercel-php@0.7.1" },
    { "src": "api/*.php",   "use": "vercel-php@0.7.1" }
  ],
  "routes": [
    { "src": "/styles/(.*)", "dest": "/styles/$1" },
    { "src": "/js/(.*)",     "dest": "/js/$1" },
    { "src": "/photos/(.*)", "dest": "/photos/$1" },
    { "src": "/api/(.+)",    "dest": "/api/$1" },
    { "src": "/(.*)\\.php",  "dest": "/$1.php" },
    { "src": "/([^/.]+)",    "dest": "/$1.php" },
    { "src": "/",            "dest": "/index.php" }
  ]
}
